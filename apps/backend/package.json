{
  "name": "@xeno-crm/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "ts-node -r dotenv/config src/scripts/seed.ts",
    "typecheck": "tsc --noEmit",
    "schema": "ts-node -r dotenv/config src/scripts/applySchema.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@mistralai/mistralai": "^2.2.5",
    "@supabase/supabase-js": "^2.48.0",
    "@xeno-crm/shared": "*",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.4.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.20.0",
    "pg": "^8.21.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.0"
  }
}
