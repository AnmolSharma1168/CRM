# =============================================================
# XenoCRM — Environment Variables
# =============================================================
# Copy this file to .env in each app directory and fill in values.
# NEVER commit .env files to git.

# -------------------------------------------------------------
# Supabase (Required for backend + seed script)
# Create a project at https://supabase.com → Settings → API
# -------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -------------------------------------------------------------
# Google Gemini AI
# Get key at https://aistudio.google.com/app/apikey
# -------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here

# -------------------------------------------------------------
# Upstash Redis (Required for BullMQ in channel service)
# Create at https://console.upstash.com → Create Database
# Use the "ioredis" compatible connection string
# -------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here
# OR use direct Redis URL (for BullMQ ioredis):
REDIS_URL=rediss://default:your-password@your-redis.upstash.io:6380

# -------------------------------------------------------------
# Backend (apps/backend)
# -------------------------------------------------------------
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
CHANNEL_SERVICE_URL=http://localhost:3002
# This is the URL the channel service will call back to:
CRM_CALLBACK_URL=http://localhost:3001/api/receipts

# -------------------------------------------------------------
# Channel Service (apps/channel-service)
# -------------------------------------------------------------
CHANNEL_SERVICE_PORT=3002
# Redis connection for BullMQ:
REDIS_URL=rediss://default:your-password@your-redis.upstash.io:6380

# -------------------------------------------------------------
# Frontend (apps/frontend) — NEXT_PUBLIC_ vars are client-safe
# -------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
